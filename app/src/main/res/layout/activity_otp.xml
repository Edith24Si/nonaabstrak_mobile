<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#2E7D32"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center"
            android:layout_marginBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔐"
                android:textSize="48sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Verifikasi OTP"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Info -->
        <TextView
            android:id="@+id/tvInfoOtp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kode OTP telah dikirim"
            android:textSize="14sp"
            android:textColor="#333333"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💡 Hint: Kode OTP = Nomor HP yang didaftarkan"
            android:textSize="12sp"
            android:textColor="#2E7D32"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Input OTP -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Masukkan Kode OTP"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#1B5E20"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etOtp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Masukkan kode OTP"
            android:inputType="number"
            android:gravity="center"
            android:textSize="24sp"
            android:background="@drawable/bg_rounded_input"
            android:padding="16dp"
            android:layout_marginBottom="24dp" />

        <!-- Tombol Verifikasi -->
        <Button
            android:id="@+id/btnVerifikasi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Verifikasi"
            android:backgroundTint="#2E7D32"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:padding="14dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>