<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#2E7D32"
        android:elevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:titleTextColor="#FFFFFF"
        app:subtitleTextColor="#C8E6C9" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#2E7D32"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏛️ Portal Regulasi Desa"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sistem pengelolaan produk hukum desa yang terintegrasi dan modern"
                    android:textColor="#C8E6C9"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Menu Navigasi"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnToSecond"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📚 Pertemuan 2"
                android:backgroundTint="#2E7D32"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnToThird"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔑 Pertemuan 3"
                android:backgroundTint="#2E7D32"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnToFourth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🏠 Pertemuan 4"
                android:backgroundTint="#2E7D32"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnToFifth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📋 Pertemuan 5"
                android:backgroundTint="#388E3C"
                android:layout_marginBottom="20dp" />

            <Button
                android:id="@+id/btnWebView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🌐 Buka Portal Regulasi Desa"
                android:backgroundTint="#1B5E20"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🚪 Logout"
                android:backgroundTint="#C62828" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>